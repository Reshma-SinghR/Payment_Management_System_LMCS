{
  "name": "electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.school.payment",
    "productName": "School Payment System",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "../backend/dist/start_backend",
        "to": "backend",
        "filter": ["**/*", "!**/*.sqlite3"]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend"
      }
    ]
  },
  "dependencies": {
    "tree-kill": "^1.2.2",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}